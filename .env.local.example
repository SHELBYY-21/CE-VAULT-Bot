# ===== Next.js / Dashboard =====
# หา 3 ค่านี้ได้จาก Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# service_role key (ห้ามเปิดเผย / ใช้เฉพาะฝั่ง server ใน API route)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# กุญแจลับป้องกัน API (บอทต้องส่ง header x-api-key ให้ตรงค่านี้)
# สร้างค่าใหม่ด้วย:  openssl rand -hex 32   (หรือใช้สตริงสุ่มยาว ๆ)
# ถ้าเว้นว่าง = ปิดการตรวจ (ใช้เฉพาะตอน dev)
API_SECRET=

# ===== Telegram Bot (webhook รันใน Next.js) =====
BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret  # ตั้งโดย /api/telegram/set-webhook
APP_URL=http://localhost:3000
SUPABASE_BUCKET=slips
FEE_WARNING_THRESHOLD=3
DEFAULT_THB=5000
DEFAULT_SELL_RATE=35.5
DEFAULT_MARKET_RATE=34.8
DEFAULT_BANK_ACCOUNT_ID=

# OCR อ่านยอดสลิปอัตโนมัติ (ไม่บังคับ) — free key: https://ocr.space/ocrapi
OCR_SPACE_API_KEY=

# Grok Vision (optional for faster slip analysis)
# GROK_API_KEY=xai-...

# ===== Telegram Stickers (ทั้งหมดเป็น optional — ไม่ใส่ = ข้ามอัตโนมัติ) =====
# วิธีหา file_id: ส่ง sticker เข้าบอท → ดู update ใน webhook log (field sticker.file_id)
# file_id ของ animated sticker ขึ้นต้นด้วย CAACAg...
STICKER_WELCOME_ID=
STICKER_PROCESSING_ID=
STICKER_OCR_DONE_ID=
STICKER_WAITING_ID=
STICKER_SUCCESS_ID=
STICKER_ERROR_ID=
STICKER_RETRY_ID=
STICKER_THANKYOU_ID=
STICKER_VIP_ID=
STICKER_QUEUE_ID=
