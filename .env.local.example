# ===== Firebase =====
# Local emulator (default for this repo):
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-ce-vault
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-ce-vault.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-ce-vault.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:demo
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=1
FIREBASE_PROJECT_ID=demo-ce-vault
FIREBASE_STORAGE_BUCKET=demo-ce-vault.appspot.com
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Production: remove emulator vars and set a real web config + service account JSON
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# กุญแจลับป้องกัน API (บอทต้องส่ง header x-api-key ให้ตรงค่านี้)
# ถ้าเว้นว่าง = ปิดการตรวจ (ใช้เฉพาะตอน dev)
API_SECRET=

# ===== Circle Smart Contract Platform (server-only) =====
CIRCLE_API_KEY=
ENTITY_SECRET=

# ===== Telegram Bot (webhook รันใน Next.js) =====
BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
APP_URL=
FEE_WARNING_THRESHOLD=3
DEFAULT_THB=5000
DEFAULT_SELL_RATE=35.5
DEFAULT_MARKET_RATE=34.8
DEFAULT_BANK_ACCOUNT_ID=

# OCR (optional)
OCR_SPACE_API_KEY=

# Telegram Stickers (optional)
